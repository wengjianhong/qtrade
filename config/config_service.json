{
  "grpc": {
    "listen": "0.0.0.0:50051"
  },
  "repository": {
    "enabled": false,
    "backend": "sqlite3",
    "sqlite": {
      "database_path": "config.db",
      "busy_timeout": 2
    },
    "pool": {
      "enabled": false,
      "size": 4,
      "lease_timeout": 0
    }
  },
  "config": {
    "version": 1,
    "entries": {
      "strategy.example.enabled": "true",
      "risk.max_loss_ratio": "0.05"
    }
  }
}
